{
  "name": "rss-dashboard",
  "version": "0.1.5",
  "private": true,
  "description": "Yayıncı tarzı RSS haber komuta merkezi (Electron masaüstü uygulaması)",
  "main": "electron/main.cjs",
  "scripts": {
    "postinstall": "npm install --prefix client",
    "dev:client": "npm run dev --prefix client",
    "dev": "concurrently -k -n vite,electron -c blue,magenta \"npm:dev:client\" \"wait-on -t 30000 http://localhost:5173 && electron .\"",
    "build:client": "npm run build --prefix client",
    "start": "npm run build:client && electron .",
    "electron": "electron .",
    "dist": "npm run build:client && electron-builder --win",
    "dist:dir": "npm run build:client && electron-builder --win --dir"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.21.1",
    "node-cache": "^5.1.2",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.ahmet.rssdashboard",
    "productName": "RSS Dashboard",
    "directories": {
      "output": "release"
    },
    "files": [
      "electron/**/*",
      "server/index.js",
      "server/main.js",
      "server/routes/**/*",
      "server/sources.json",
      "server/channels.json",
      "server/package.json",
      "client/dist/**/*",
      "package.json",
      "node_modules/**/*",
      "!node_modules/electron/**/*",
      "!node_modules/electron-builder/**/*",
      "!node_modules/concurrently/**/*",
      "!node_modules/wait-on/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "electron/assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RSS Dashboard"
    }
  }
}
